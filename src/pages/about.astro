---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About us | WIDA">
  <main class="about-page">
    <section class="about-hero">

      <h1>About WIDA</h1>

      <p>
        WIDA is an ECL organization from Finland focused on building competitive teams,
        a strong community, and a recognizable presence in the NHL esports scene.
      </p>
    </section>

    <section class="about-card">
      <h2>Who we are</h2>

      <p>
        Wida is an esports organization competing in the ECL, with teams in both the Pro
        and Core divisions. What started as a shared passion has grown into a structured
        and competitive project, built by people who care about both performance and
        community.
      </p>

      <p> We are not here for a single season. We are here to build something that lasts.</p>

    </section>


<section class="founders-section">
  <h2>Meet our founders</h2>

  <div class="founders-grid">
    <div class="founder-card">
      <img src="/about/founders/founders.jpg" alt="Founder portrait" />

      <h3>Founder Name</h3>
      <p>Founder & GM</p>
    </div>

    <div class="founder-card">
      <img src="/about/founders/founders.jpg" alt="Founder portrait" />

      <h3>Founder Name</h3>
      <p>Video editor, AGM</p>
    </div>

    <div class="founder-card">
      <img src="/about/founders/founders.jpg" alt="Founder portrait" />

      <h3>Founder Name</h3>
      <p>Co-Founder</p>
    </div>
  </div>
</section>



    <section class="about-grid">
      <div class="about-box">
        <h3>Competitive mindset</h3>
        <p>
          We aim to improve every season and represent WIDA with commitment and ambition.
        </p>
      </div>

      <div class="about-box">
        <h3>Community first</h3>
        <p>
          We want followers, players, and staff to feel connected to the organization.
        </p>
      </div>

      <div class="about-box">
        <h3>Long-term growth</h3>
        <p>
          WIDA is built with the goal of becoming stronger both on and off the ice.
        </p>
      </div>
    </section>
  </main>

  <style>
.about-page {
  min-height: 100vh;
  padding: 11rem 2rem 6rem;
}

    .about-hero {
      max-width: 900px;
      margin: 0 auto 5rem;
      text-align: center;
    }

    .about-logo {
      width: 140px;
      margin-bottom: 1.5rem;
    }

    .about-hero h1 {
      font-size: clamp(3rem, 8vw, 7rem);
      letter-spacing: 5px;
      margin: 0 0 1rem;
    }

    .about-hero p {
      max-width: 750px;
      margin: 0 auto;
      font-size: 1.2rem;
      line-height: 1.6;
      opacity: 0.85;
    }


    .founders-section {
  max-width: 1200px;
  margin: 6rem auto;
  text-align: center;
}

.founders-section h2 {
  font-size: clamp(3rem, 7vw, 6rem);
  margin-bottom: 4rem;
}

.founders-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 4rem;
  align-items: start;
}

.founder-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.founder-card img {
  width: 260px;
  height: 260px;
  object-fit: cover;
  border-radius: 50%;
  margin-bottom: 1.5rem;
}

.founder-card h3 {
  color: white;
  font-size: 1.3rem;
  letter-spacing: 2px;
  text-transform: uppercase;
  margin: 0 0 0.4rem;
}

.founder-card p {
  font-size: 1.1rem;
  margin: 0;
  opacity: 0.9;
}

    .about-card {
      max-width: 1000px;
      margin: 0 auto 4rem;
      padding: 4rem;
      background: #242424;
      border-radius: 40px;
      box-shadow: 0 20px 50px rgba(0,0,0,.35);
      text-align: center;
    }

    .about-card h2 {
      font-size: clamp(2rem, 5vw, 4rem);
      margin-top: 0;
      margin-bottom: 2rem;
    }

    .about-card p {
      max-width: 750px;
      margin: 0 auto 1.5rem;
      font-size: 1.1rem;
      line-height: 1.7;
      opacity: 0.85;
    }

    .about-grid {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }

    .about-box {
      background: rgba(0,0,0,.55);
      backdrop-filter: blur(10px);
      padding: 2rem;
      border-radius: 24px;
      text-align: center;
      border: 1px solid rgba(103,149,64,.35);
    }

    .about-box h3 {
  color: #679540;
  text-transform: uppercase;
  letter-spacing: 2px;
  margin-top: 0;
  margin-bottom: 1.5rem;

  min-height: 3.2rem;

  display: flex;
  align-items: center;
  justify-content: center;

  text-align: center;
}

    .about-box p {
      line-height: 1.6;
      opacity: 0.85;
    }

    @media (max-width: 800px) {
      .about-page {
        padding: 7rem 1rem 4rem;
      }
      .about-logo {
        width: 110px;
      }

      .about-hero {
        margin-bottom: 3rem;
      }

      .about-hero h1 {
        font-size: clamp(2.5rem, 14vw, 4rem);
        letter-spacing: 2px;
      }

      .about-hero p {
        font-size: 0.95rem;
      }


.founders-section {
  margin: 4rem auto;
}

.founders-section h2 {
  font-size: clamp(2.4rem, 11vw, 4rem);
  margin-bottom: 3rem;
}

.founders-grid {
  grid-template-columns: 1fr;
  gap: 3rem;
}

.founder-card img {
  width: 220px;
  height: 220px;
}

.founder-card h3 {
  font-size: 1.1rem;
}

.founder-card p {
  font-size: 1rem;
}


      .about-card {
        padding: 3rem 1.5rem;
        border-radius: 28px;
      }

      .about-card p {
        font-size: 0.95rem;
      }

      .about-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</Layout>