---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Stats | WIDA">
  <main class="stats-page">
    <section class="stats-hero">
      <h1>Stats</h1>

      <p class="stats-intro">
        Here you can find all-time stats tables for WIDA players and goalkeepers.
      </p>

      <div class="stats-jump">
        <p>Go to</p>

        <nav class="stats-nav" aria-label="Stats sections">
          <a href="#organization">ORG</a>
          <a href="#wida">WIDA</a>
          <a href="#wigor">WIGOR</a>
          <a href="#wibe">WIBE</a>
        </nav>
      </div>
    </section>

    <div class="stats-sections" data-stats-sections>
      <p class="loading-message">Loading stats...</p>
    </div>
  </main>

  <style is:global>
    .stats-page {
      min-height: 100vh;
      padding: 12rem 2rem 6rem;
    }

    .stats-hero {
      max-width: 1100px;
      margin: 0 auto 7rem;
      text-align: center;

      padding: 3rem 2rem;
      background: rgba(0,0,0,.42);
      border: 1px solid rgba(103,149,64,.22);
      border-radius: 36px;
      backdrop-filter: blur(6px);
      box-shadow: 0 20px 50px rgba(0,0,0,.28);
    }

    .stats-hero h1 {
      font-size: clamp(4rem, 9vw, 8rem);
      line-height: 1.05;
      letter-spacing: 2px;
      margin: 0 0 2rem;
    }

    .stats-intro {
      max-width: 760px;
      margin: 0 auto 3rem;
      font-size: 1.15rem;
      line-height: 1.7;
      color: rgba(255,255,255,.95);
      text-shadow: 0 2px 12px rgba(0,0,0,.65);
    }

    .stats-jump {
      margin-top: 2.5rem;
    }

    .stats-jump p {
      color: #679540;
      font-family: 'Michroma', sans-serif;
      font-size: 0.75rem;
      letter-spacing: 2px;
      text-transform: uppercase;
      margin: 0 0 1rem;
    }

    .stats-nav {
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 0.8rem;
    }

    .stats-nav a {
      color: white;
      text-decoration: none;
      font-family: 'Michroma', sans-serif;
      font-size: 0.75rem;
      letter-spacing: 2px;
      text-transform: uppercase;

      padding: 0.9rem 1.2rem;

      background: rgba(0,0,0,.45);
      border: 1px solid rgba(103,149,64,.35);
      border-radius: 999px;

      transition:
        background 0.2s ease,
        border-color 0.2s ease,
        transform 0.2s ease;
    }

    .stats-nav a:hover {
      background: rgba(103,149,64,.18);
      border-color: rgba(103,149,64,.8);
      transform: translateY(-2px);
    }

    .stats-sections {
      max-width: 1400px;
      margin: 0 auto;
    }

    .stats-group {
      scroll-margin-top: 8rem;
      margin-bottom: 7rem;
    }

    .section-heading {
      margin-bottom: 2rem;
      text-align: left;

      padding: 1.5rem 1.7rem;
      background: rgba(0,0,0,.35);
      border: 1px solid rgba(103,149,64,.18);
      border-radius: 26px;
      backdrop-filter: blur(6px);
    }

    .section-heading p {
      color: #679540;
      font-family: 'Michroma', sans-serif;
      font-size: 0.8rem;
      letter-spacing: 3px;
      text-transform: uppercase;
      margin: 0 0 0.8rem;
    }

    .section-heading h2 {
      font-size: clamp(2.2rem, 5vw, 4.6rem);
      line-height: 1.1;
      margin: 0 0 1rem;
    }

    .section-heading span {
      display: block;
      max-width: 700px;
      color: rgba(255,255,255,.92);
      line-height: 1.6;
      text-shadow: 0 2px 12px rgba(0,0,0,.6);
    }

    .tables-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .table-card {
      background: rgba(36,36,36,.94);
      border: 1px solid rgba(103,149,64,.28);
      border-radius: 34px;
      box-shadow: 0 20px 50px rgba(0,0,0,.35);
      overflow: hidden;
    }

    .table-title {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;

      padding: 1.5rem 1.6rem;
      border-bottom: 1px solid rgba(103,149,64,.22);
      background: rgba(0,0,0,.25);
    }

    .table-title p {
      color: #679540;
      font-family: 'Michroma', sans-serif;
      font-size: 0.72rem;
      letter-spacing: 2px;
      text-transform: uppercase;
      margin: 0 0 0.35rem;
    }

    .table-title h3 {
      margin: 0;
      font-size: 1.5rem;
    }

    .table-title > span {
      white-space: nowrap;
      color: white;
      opacity: 0.75;
      font-size: 0.9rem;
    }

    .table-scroll {
      width: 100%;
      overflow-x: auto;
    }

    table {
      width: 100%;
      min-width: 800px;
      border-collapse: collapse;
    }

    th,
    td {
      padding: 1.1rem 1rem;
      text-align: center;
      border-bottom: 1px solid rgba(255,255,255,.08);
    }

    th {
      color: #111;
      background: #e6e6e6;
      font-family: 'Michroma', sans-serif;
      font-size: 0.72rem;
      letter-spacing: 1px;
      text-transform: uppercase;
    }

    tbody tr {
      transition: background 0.2s ease;
    }

    tbody tr:hover {
      background: rgba(103,149,64,.12);
    }

    tbody tr:last-child td {
      border-bottom: none;
    }

    .player-cell {
      text-align: left;
      min-width: 220px;
    }

    .team-cell {
      font-family: 'Michroma', sans-serif;
      font-size: 0.75rem;
      letter-spacing: 1px;
      text-transform: uppercase;
      opacity: 0.9;
    }

    .empty-table,
    .loading-message,
    .error-message {
      padding: 2rem;
      margin: 0;
      text-align: center;
      background: rgba(0,0,0,.35);
      border: 1px solid rgba(103,149,64,.18);
      border-radius: 24px;
    }

    .error-message {
      border-color: rgba(255,80,80,.35);
    }

    @media (max-width: 900px) {
      .section-heading {
        text-align: center;
      }

      .section-heading span {
        margin: 0 auto;
      }
    }

    @media (max-width: 800px) {
      .stats-page {
        padding: 8rem 1rem 4rem;
      }

      .stats-hero {
        margin-bottom: 4rem;
        padding: 2.2rem 1rem;
        border-radius: 28px;
      }

      .stats-hero h1 {
        font-size: clamp(3rem, 15vw, 4.8rem);
        letter-spacing: 1px;
      }

      .stats-intro {
        font-size: 0.95rem;
      }

      .stats-nav {
        gap: 0.6rem;
      }

      .stats-nav a {
        font-size: 0.68rem;
        padding: 0.75rem 0.9rem;
      }

      .stats-group {
        margin-bottom: 4.5rem;
      }

      .table-card {
        border-radius: 26px;
      }

      .table-title {
        align-items: flex-start;
        flex-direction: column;
      }

      .table-title h3 {
        font-size: 1.25rem;
      }

      th,
      td {
        padding: 0.9rem 0.8rem;
        font-size: 0.9rem;
      }
    }
  </style>

  <script>
    type PlayerStat = {
      team: string;
      player: string;
      games: number;
      goals: number;
      assists: number;
      points: number;
    };

    type GoalieStat = {
      team: string;
      player: string;
      games: number;
      saves: number;
      pm: number;
      ly: number;
      savePercentage: number;
      gaa: number;
    };

    type StatGroup = {
      id: string;
      label: string;
      title: string;
      description: string;
      players: PlayerStat[];
      goalies: GoalieStat[];
    };

    const statsContainer = document.querySelector('[data-stats-sections]');

    const escapeHtml = (value: unknown) => {
      return String(value ?? '')
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#039;');
    };

    const formatTeam = (team: string) => {
      if (team === 'wida') return 'Wida';
      if (team === 'wigor') return 'Wigor';
      if (team === 'wibe') return 'Wibe';

      return team;
    };

    const formatNumber = (value: number) => {
      return Number.isFinite(value) ? String(value).replace('.', ',') : '0';
    };

    const renderPlayerRows = (players: PlayerStat[]) => {
      if (players.length === 0) {
        return `<p class="empty-table">Player stats coming soon.</p>`;
      }

      return `
        <div class="table-scroll">
          <table>
            <thead>
              <tr>
                <th>Team</th>
                <th>Player</th>
                <th>Games</th>
                <th>Goals</th>
                <th>Assists</th>
                <th>Points</th>
              </tr>
            </thead>

            <tbody>
              ${players
                .map(
                  (player) => `
                    <tr>
                      <td class="team-cell">${escapeHtml(formatTeam(player.team))}</td>
                      <td class="player-cell">${escapeHtml(player.player)}</td>
                      <td>${formatNumber(player.games)}</td>
                      <td>${formatNumber(player.goals)}</td>
                      <td>${formatNumber(player.assists)}</td>
                      <td>${formatNumber(player.points)}</td>
                    </tr>
                  `
                )
                .join('')}
            </tbody>
          </table>
        </div>
      `;
    };

    const renderGoalieRows = (goalies: GoalieStat[]) => {
      if (goalies.length === 0) {
        return `<p class="empty-table">Goalkeeper stats coming soon.</p>`;
      }

      return `
        <div class="table-scroll">
          <table>
            <thead>
              <tr>
                <th>Team</th>
                <th>Goalkeeper</th>
                <th>Games</th>
                <th>Saves</th>
                <th>PM</th>
                <th>LY</th>
                <th>S%</th>
                <th>GAA</th>
              </tr>
            </thead>

            <tbody>
              ${goalies
                .map(
                  (goalie) => `
                    <tr>
                      <td class="team-cell">${escapeHtml(formatTeam(goalie.team))}</td>
                      <td class="player-cell">${escapeHtml(goalie.player)}</td>
                      <td>${formatNumber(goalie.games)}</td>
                      <td>${formatNumber(goalie.saves)}</td>
                      <td>${formatNumber(goalie.pm)}</td>
                      <td>${formatNumber(goalie.ly)}</td>
                      <td>${formatNumber(goalie.savePercentage)}%</td>
                      <td>${formatNumber(goalie.gaa)}</td>
                    </tr>
                  `
                )
                .join('')}
            </tbody>
          </table>
        </div>
      `;
    };

    const renderStats = (groups: StatGroup[]) => {
      if (!statsContainer) return;

      statsContainer.innerHTML = groups
        .map(
          (group) => `
            <section class="stats-group" id="${escapeHtml(group.id)}">
              <div class="section-heading">
                <p>${escapeHtml(group.label)}</p>
                <h2>${escapeHtml(group.title)}</h2>
                <span>${escapeHtml(group.description)}</span>
              </div>

              <div class="tables-grid">
                <article class="table-card">
                  <div class="table-title">
                    <div>
                      <p>Players</p>
                      <h3>Point leaders</h3>
                    </div>

                    <span>ECL</span>
                  </div>

                  ${renderPlayerRows(group.players)}
                </article>

                <article class="table-card">
                  <div class="table-title">
                    <div>
                      <p>Goalkeepers</p>
                      <h3>Goalie stats</h3>
                    </div>

                    <span>ECL</span>
                  </div>

                  ${renderGoalieRows(group.goalies)}
                </article>
              </div>
            </section>
          `
        )
        .join('');
    };

    const loadStats = async () => {
      if (!statsContainer) return;

      try {
        const response = await fetch('/api/stats', {
        cache: 'no-store',
});

        if (!response.ok) {
          throw new Error('Could not load stats.');
        }

        const data = await response.json();

        renderStats(data.statGroups);
      } catch (error) {
        statsContainer.innerHTML = `
          <p class="error-message">
            Could not load stats. Please try again later.
          </p>
        `;
      }
    };

    loadStats();
  </script>
</Layout>