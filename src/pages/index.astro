---
import Layout from '../layouts/Layout.astro';
---

<Layout title="WIDA">
  <section class="hero">

    <h1>WIDA</h1>

    <p>ECL organisation from Finland</p>

    <div class="divider"></div>

    <div class="socials">
      <a href="https://discord.com/invite/EbpBmBbVuz" target="_blank" rel="noopener noreferrer">
        <i class="fab fa-discord"></i>
      </a>

      <a href="https://www.twitch.tv/widaesport" target="_blank" rel="noopener noreferrer" class="social-icon twitch-icon">
        <i class="fab fa-twitch"></i>
        <span class="live-badge">LIVE</span>
      </a>

      <a href="https://www.instagram.com/widaesport/" target="_blank" rel="noopener noreferrer">
        <i class="fab fa-instagram"></i>
      </a>

      <a href="https://x.com/widaesport" target="_blank" rel="noopener noreferrer">
        <i class="fab fa-x-twitter"></i>
      </a>

      <a href="https://www.youtube.com/@widaesport" target="_blank" rel="noopener noreferrer">
        <i class="fab fa-youtube"></i>
      </a>

      <a href="https://www.tiktok.com/@widaesport?_r=1&_t=ZN-93ztEUKhobm" target="_blank" rel="noopener noreferrer">
        <i class="fab fa-tiktok"></i>
      </a>
    </div>

    <section class="about">
      <h2>Follow us on social media</h2>

      <p>
        Wida aims to maintain an active presence on social media.
        Become part of the story and follow us through the links above!
      </p>

      <div class="divider2"></div>
    </section>
  </section>

  <section class="community-section slide-in from-right">
    <div class="community-content">
      <h2>Wida, growing ECL organization</h2>

      <p>
        Our goal is to build the Wida community and make it easy for our
        followers to follow the team. Join the Wida Discord server to stay
        up to date with upcoming matches!
      </p>

      <a href="https://discord.com/invite/EbpBmBbVuz" target="_blank" rel="noopener noreferrer" class="discord-button">
        Join Wida's Discord server
      </a>
    </div>

    <div class="community-image">
      <img src="/home/homepage1.png" alt="WIDA player" />
    </div>
  </section>

  <section class="values-section slide-in from-left">
    <h2>Our values</h2>

    <div class="value-row">
      <img src="/home/value1.png" alt="Growth" />
      <h3>Growth</h3>
      <p>
        We strive to improve every day, both individually and as a team,
        in and out of the game.
      </p>
    </div>

    <div class="value-row">
      <img src="/home/value2.png" alt="Community" />
      <h3>Community</h3>
      <p>
        Wida is more than a team. We build an open and supportive
        community for players and followers.
      </p>
    </div>

    <div class="value-row">
      <img src="/home/value3.png" alt="Commitment" />
      <h3>Commitment</h3>
      <p>
        We are committed to long-term growth, as players, as leaders,
        and as an organization.
      </p>
    </div>
  </section>

  <style>
    .social-icon {
      position: relative;
    }

    .live-badge {
      position: absolute;
      top: -8px;
      right: -12px;

      background: #ff2b2b;
      color: white;

      font-size: 0.65rem;
      font-weight: 800;

      padding: 0.2rem 0.45rem;
      border-radius: 999px;

      letter-spacing: 1px;
    }

    .hero {
  min-height: 100vh;

  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;

  position: relative;
  padding: 13rem 2rem 4rem;
  text-align: center;
}


    h1 {
      font-size: clamp(4rem, 10vw, 10rem);
      letter-spacing: 6px;
      margin: 0;
    }

    p {
      font-size: 1.2rem;
      opacity: 0.85;
      margin-top: 0.5rem;
      margin-bottom: 2rem;
    }

    .divider,
    .divider2 {
      width: 500px;
      height: 2px;

      background:
        linear-gradient(to right, transparent, white, transparent);

      margin: 2rem auto;
    }

    .divider {
      margin-top: 0;
    }

    .socials {
      display: flex;
      gap: 1rem;
    }

    .socials a {
      width: 70px;
      height: 70px;

      display: flex;
      align-items: center;
      justify-content: center;

      border: 1px solid #679540;
      border-radius: 50%;

      color: white;
      text-decoration: none;

      font-size: 2rem;

      backdrop-filter: blur(10px);

      transition:
        transform .2s ease,
        background .2s ease,
        box-shadow .2s ease;
    }

    .socials a:hover {
      background: #679540;

      transform: translateY(-4px);

      box-shadow:
        0 0 20px rgba(103,149,64,.7);
    }

    .about {
      padding: 2rem 2rem;
      text-align: center;
    }

    .about h2 {
      font-size: 2.5rem;
      letter-spacing: 4px;
      margin-bottom: 1rem;
      margin-top: 1rem;
    }

    .about p {
      max-width: 700px;
      margin: 0 auto;

      line-height: 1.5;
      opacity: 0.8;

      font-size: 1.1rem;
    }

    .community-section,
    .values-section {
      width: 82%;

      background: #242424;
      color: white;

      overflow: hidden;

      box-shadow:
        0 20px 50px rgba(0,0,0,.35);
    }

    .community-section {
      margin-top: 4rem;
      margin-bottom: 4rem;

      margin-left: auto;
      margin-right: 0;

      padding: 6rem 5%;

      display: grid;
      grid-template-columns: 1fr 1fr;

      gap: 4rem;

      border-radius: 40px 0 0 40px;
    }

    .values-section {
      margin-top: 4rem;
      margin-bottom: 4rem;

      margin-left: 0;
      margin-right: auto;

      padding: 8rem 5%;

      border-radius: 0 40px 40px 0;
    }

    .community-content {
      display: flex;
      flex-direction: column;
      align-items: center;

      text-align: center;
    }

    .community-content h2 {
      font-size: clamp(2.5rem, 5vw, 4.5rem);
      line-height: 1.1;
      margin-bottom: 2rem;
    }

    .community-content p {
      font-size: 1.4rem;
      line-height: 1.6;
      max-width: 600px;
      margin-bottom: 2.5rem;
    }

    .discord-button {
      display: inline-block;

      background: #679540;
      color: #0b0b0b;

      padding: 1rem 1.5rem;

      font-weight: 700;
      text-decoration: none;

      transition: 0.2s ease;

      border-radius: 10px;
    }

    .discord-button:hover {
      background: #7caf4d;

      transform: translateY(-2px);
    }

    .community-image img {
      width: 100%;
      max-height: 520px;

      object-fit: cover;
    }

    .values-section h2 {
      font-size: clamp(2.5rem, 5vw, 4.5rem);
      margin-bottom: 3rem;
    }

    .value-row {
      display: grid;
      grid-template-columns: 320px 220px 1fr;

      gap: 2rem;

      align-items: center;

      padding: 1.5rem 0;

      border-bottom: 1px solid rgba(255, 255, 255, 0.45);
    }

    .value-row h3,
    .value-row p {
      margin-top: 0;
      margin-bottom: 0;
    }

    .value-row img {
      width: 100%;
      height: 120px;

      object-fit: cover;
    }

    .value-row h3 {
      font-size: 1.4rem;
      text-transform: uppercase;
    }

    .value-row p {
      font-size: 1.1rem;
      line-height: 1.5;
      max-width: 650px;
    }

    .slide-in {
      opacity: 0;

      transition:
        opacity 0.8s ease,
        transform 0.8s ease;
    }

    .from-right {
      transform: translateX(120px);
    }

    .from-left {
      transform: translateX(-120px);
    }

    .slide-in.visible {
      opacity: 1;
      transform: translateX(0);
    }

    @media (max-width: 800px) {
  .hero {
    min-height: 0 !important;
    height: auto !important;
    justify-content: flex-start;
    padding: 7rem 1rem 1rem;
  }


      h1 {
        font-size: clamp(2.8rem, 16vw, 4.5rem);
        letter-spacing: 3px;
      }

      .hero > p {
        font-size: 0.85rem;
        margin-top: 0.4rem;
        margin-bottom: 1.2rem;
      }

      .divider,
      .divider2 {
        width: min(500px, 85vw);
        margin: 1.2rem auto;
      }

      .socials {
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.6rem;
        margin-bottom: 1.2rem;
      }

      .socials a {
        width: 42px;
        height: 42px;
        font-size: 1.1rem;
      }

      .live-badge {
        top: -7px;
        right: -10px;
        font-size: 0.5rem;
        padding: 0.15rem 0.35rem;
      }

      .about {
        padding: 0 1rem;
      }

      .about h2 {
        font-size: clamp(1.3rem, 7vw, 2rem);
        letter-spacing: 1px;
        line-height: 1.25;
        margin-top: 0;
        margin-bottom: 0.8rem;
      }

      .about p {
        font-size: 0.85rem;
        line-height: 1.5;
        margin-bottom: 1rem;
      }

      .community-section {
        width: calc(100% - 2rem);
        margin: 1rem auto 2rem;
        padding: 3rem 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 2rem;
        border-radius: 28px;
      }

      .community-content h2 {
        font-size: clamp(1.6rem, 9vw, 2.4rem);
        margin-bottom: 1.2rem;
      }

      .community-content p {
        font-size: 0.95rem;
        line-height: 1.5;
        margin-bottom: 1.5rem;
      }

      .community-image img {
        max-height: 260px;
        border-radius: 12px;
      }

      .values-section {
        width: calc(100% - 2rem);
        margin: 2rem auto;
        padding: 3rem 1.5rem;
        border-radius: 28px;
      }

      .values-section h2 {
        font-size: clamp(1.8rem, 9vw, 2.6rem);
        margin-bottom: 2rem;
        text-align: center;
      }

      .value-row {
        display: flex;
        flex-direction: column;
        text-align: center;
        gap: 1rem;
        padding: 1.5rem 0;
      }

      .value-row img {
        height: 140px;
      }

      .value-row h3 {
        font-size: 1.1rem;
      }

      .value-row p {
        font-size: 0.9rem;
      }
    }
  </style>

  <script>
    const twitchLive = true;

    const liveBadge = document.querySelector('.live-badge') as HTMLElement;

    if (!twitchLive && liveBadge) {
      liveBadge.style.display = 'none';
    }

    const slideElements = document.querySelectorAll('.slide-in');

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, {
      threshold: 0.2
    });

    slideElements.forEach((element) => {
      observer.observe(element);
    });
  </script>
</Layout>