---
import '@fortawesome/fontawesome-free/css/all.min.css';
---

<div class="page-bg"></div>

<section class="hero">
  <button class="burger">&#9776;</button>

  <nav class="navbar">
    <a href="/">Home</a>

    <button class="dropdown-toggle">
      Teams <span>&#9662;</span>
    </button>

    <div class="dropdown-menu">
      <a href="/teams/ecl">ECL Team</a>
      <a href="/teams/lite">Lite Team</a>
      <a href="/teams/pro">Pro Team</a>
    </div>

    <a href="/contact">Contact</a>
  </nav>

  <img src="/WIDAlogo.png" class="logo" alt="WIDA logo" />

  <h1>WIDA</h1>

  <p>ECL organisation from Finland</p>

  <div class="divider"></div>

  <div class="socials">
    <a href="https://discord.com/invite/EbpBmBbVuz" target="_blank" rel="noopener noreferrer"><i class="fab fa-discord"></i></a>
    <a href="https://www.twitch.tv/widaesport" target="_blank" rel="noopener noreferrer"><i class="fab fa-twitch"></i></a>
    <a href="https://www.instagram.com/widaesport/" target="_blank" rel="noopener noreferrer"><i class="fab fa-instagram"></i></a>
    <a href="https://x.com/widaesport" target="_blank" rel="noopener noreferrer"><i class="fab fa-x-twitter"></i></a>
    <a href="https://www.youtube.com/@widaesport" target="_blank" rel="noopener noreferrer"><i class="fab fa-youtube"></i></a>
    <a href="https://www.tiktok.com/@widaesport?_r=1&_t=ZN-93ztEUKhobm" target="_blank" rel="noopener noreferrer"><i class="fab fa-tiktok"></i></a>
  </div>

  <section class="about">
    <h2>Follow us on social media</h2>

    <p>
      Wida aims to maintain an active presence on social media.
      Become part of the story and follow us through the links above!
    </p>

    <div class="divider2"></div>
  </section>
</section>

<section class="community-section slide-in from-right">
  <div class="community-content">
    <h2>Wida, growing ECL organization</h2>

    <p>
      Our goal is to build the Wida community and make it easy for our
      followers to follow the team. Join the Wida Discord server to stay
      up to date with upcoming matches!
    </p>

    <a href="https://discord.com/invite/EbpBmBbVuz" class="discord-button">
      Join Wida's Discord server
    </a>
  </div>

  <div class="community-image">
    <img src="/home/homepage1.png" alt="WIDA player" />
  </div>
</section>

<section class="values-section slide-in from-left">
  <h2>Our values</h2>

  <div class="value-row">
    <img src="/home/value1.png" alt="Growth" />
    <h3>Growth</h3>
    <p>
      We strive to improve every day, both individually and as a team,
      in and out of the game.
    </p>
  </div>

  <div class="value-row">
    <img src="/home/value2.png" alt="Community" />
    <h3>Community</h3>
    <p>
      Wida is more than a team. We build an open and supportive
      community for players and followers.
    </p>
  </div>

  <div class="value-row">
    <img src="/home/value3.png" alt="Commitment" />
    <h3>Commitment</h3>
    <p>
      We are committed to long-term growth, as players, as leaders,
      and as an organization.
    </p>
  </div>
</section>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Michroma&display=swap');

  html,
  body {
    margin: 0;
    padding: 0;
    width: 100%;
    overflow-x: hidden;
  }

  * {
    box-sizing: border-box;
  }

  body {
    font-family: sans-serif;
    color: white;
    background: #0b0b0b;
  }

.page-bg {
  position: fixed;

  top: -30%;
  left: -10%;

  width: 120%;
  height: 160%;

  background:
    linear-gradient(rgba(0,0,0,.45), rgba(0,0,0,.45)),
    url('/backgrounds/widabackground.png');

  background-size: cover;
  background-position: center;

  z-index: -1;
  will-change: transform;
}

  .hero {
    min-height: 100vh;

    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;

    position: relative;
    padding: 2rem;
    text-align: center;
  }

  .burger {
    position: fixed;
    top: 2rem;
    left: 2rem;

    background: transparent;
    border: none;

    color: white;
    font-size: 2rem;

    cursor: pointer;
    z-index: 1000;
  }

  .navbar {
    position: fixed;
    z-index: 999;

    top: 0;
    left: 0;
    bottom: 0;

    height: 100vh;
    width: 250px;

    background: rgba(0,0,0,.9);

    display: flex;
    flex-direction: column;
    align-items: flex-start;

    padding-top: 6rem;

    transform: translateX(-100%);
    transition: transform .3s ease;
  }

  .navbar.open {
    transform: translateX(0);
  }

  .navbar a,
  .dropdown-toggle {
    width: 100%;

    color: white;
    text-decoration: none;

    padding: 1rem 2rem;

    font-size: 1.2rem;

    text-align: left;
  }

  .dropdown-toggle {
    background: transparent;
    border: none;

    cursor: pointer;

    display: flex;
    align-items: center;
    justify-content: flex-start;

    gap: 0.5rem;
  }

  .dropdown-menu {
    display: none;
    flex-direction: column;

    width: 100%;

    background: rgba(255,255,255,0.04);
  }

  .dropdown-menu a {
    padding-left: 3rem;
    font-size: 1rem;
    opacity: 0.85;
  }

  .dropdown-menu.open {
    display: flex;
  }

  .logo {
    width: 180px;
    margin-bottom: 1rem;
  }

  h1,
  h2,
  h3 {
    font-family: 'Michroma', sans-serif;
  }

  h1 {
    font-size: clamp(4rem, 10vw, 10rem);
    letter-spacing: 6px;
    margin: 0;
  }

  p {
    font-size: 1.2rem;
    opacity: 0.85;
    margin-top: 0.5rem;
    margin-bottom: 2rem;
  }

  .divider,
  .divider2 {
    width: 500px;
    height: 2px;

    background:
      linear-gradient(to right, transparent, white, transparent);

    margin: 2rem auto;
  }

  .divider {
    margin-top: 0;
  }

  .socials {
    display: flex;
    gap: 1rem;
  }

  .socials a {
    width: 70px;
    height: 70px;

    display: flex;
    align-items: center;
    justify-content: center;

    border: 1px solid #679540;
    border-radius: 50%;

    color: white;
    text-decoration: none;

    font-size: 2rem;

    backdrop-filter: blur(10px);

    transition:
      transform .2s ease,
      background .2s ease,
      box-shadow .2s ease;
  }

  .socials a:hover {
    background: #679540;

    transform: translateY(-4px);

    box-shadow:
      0 0 20px rgba(103,149,64,.7);
  }

  .about {
    padding: 2rem 2rem;
    text-align: center;
  }

  .about h2 {
    font-size: 2.5rem;
    letter-spacing: 4px;
    margin-bottom: 1rem;
    margin-top: 1rem;
  }

  .about p {
    max-width: 700px;
    margin: 0 auto;

    line-height: 1.5;
    opacity: 0.8;

    font-size: 1.1rem;
  }

  .community-section,
  .values-section {
    width: 82%;

    background: #242424;
    color: white;

    overflow: hidden;

    box-shadow:
      0 20px 50px rgba(0,0,0,.35);
  }

  .community-section {
    margin-top: 4rem;
    margin-bottom: 4rem;

    margin-left: auto;
    margin-right: 0;

    padding: 6rem 5%;

    display: grid;
    grid-template-columns: 1fr 1fr;

    gap: 4rem;

    border-radius: 40px 0 0 40px;
  }

  .values-section {
    margin-top: 4rem;
    margin-bottom: 4rem;

    margin-left: 0;
    margin-right: auto;

    padding: 8rem 5%;

    border-radius: 0 40px 40px 0;
  }

  .community-content {
    display: flex;
    flex-direction: column;
    align-items: center;

    text-align: center;
  }

  .community-content h2 {
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    line-height: 1.1;
    margin-bottom: 2rem;
  }

  .community-content p {
    font-size: 1.4rem;
    line-height: 1.6;
    max-width: 600px;
    margin-bottom: 2.5rem;
  }

  .discord-button {
    display: inline-block;

    background: #679540;
    color: #0b0b0b;

    padding: 1rem 1.5rem;

    font-weight: 700;
    text-decoration: none;

    transition: 0.2s ease;

    border-radius: 10px;
  }

  .discord-button:hover {
    background: #7caf4d;

    transform: translateY(-2px);
  }

  .community-image img {
    width: 100%;
    max-height: 520px;

    object-fit: cover;
  }

  .values-section h2 {
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    margin-bottom: 3rem;
  }

  .value-row {
    display: grid;
    grid-template-columns: 320px 220px 1fr;

    gap: 2rem;

    align-items: center;

    padding: 1.5rem 0;

    border-bottom: 1px solid rgba(255, 255, 255, 0.45);
  }

  .value-row h3,
  .value-row p {
    margin-top: 0;
    margin-bottom: 0;
  }

  .value-row img {
    width: 100%;
    height: 120px;

    object-fit: cover;
  }

  .value-row h3 {
    font-size: 1.4rem;
    text-transform: uppercase;
  }

  .value-row p {
    font-size: 1.1rem;
    line-height: 1.5;
    max-width: 650px;
  }

  .slide-in {
    opacity: 0;

    transition:
      opacity 0.8s ease,
      transform 0.8s ease;
  }

  .from-right {
    transform: translateX(120px);
  }

  .from-left {
    transform: translateX(-120px);
  }

  .slide-in.visible {
    opacity: 1;
    transform: translateX(0);
  }

  @media (max-width: 800px) {
    html,
    body {
      width: 100%;
      overflow-x: hidden;
    }

    * {
      box-sizing: border-box;
    }

    .hero {
      min-height: 100vh;
      width: 100%;

      padding: 1.5rem;

      text-align: center;
    }

    .logo {
      width: 120px;
    }

    h1 {
      font-size: clamp(3rem, 18vw, 5rem);
      letter-spacing: 3px;
    }

    .socials {
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.7rem;
    }

    .socials a {
      width: 52px;
      height: 52px;

      font-size: 1.4rem;
    }

    .divider,
    .divider2 {
      width: 80%;
      max-width: 500px;
    }

    .about {
      padding: 1rem;
    }

    .about h2 {
      font-size: 1.7rem;
      letter-spacing: 2px;
    }

    .about p {
      font-size: 0.95rem;
      line-height: 1.5;
    }

    .community-section,
    .values-section {
      width: calc(100% - 2rem);

      margin: 3rem auto;

      padding: 2rem 1.2rem;

      border-radius: 24px;

      box-sizing: border-box;
    }

    .community-section {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .community-image {
      order: -1;
    }

    .community-image img {
      width: 100%;
      max-height: 260px;

      object-fit: cover;
    }

    .community-content {
      text-align: center;
    }

    .community-content h2 {
      font-size: 2rem;
      line-height: 1.15;
    }

    .community-content p {
      font-size: 1rem;
      line-height: 1.5;
    }

    .discord-button {
      width: 100%;
      text-align: center;
    }

    .values-section h2 {
      font-size: 2rem;
      text-align: center;
    }

    .value-row {
      grid-template-columns: 1fr;
      gap: 1rem;
      text-align: center;
    }

    .value-row img {
      width: 100%;
      height: 180px;

      object-fit: cover;
    }

    .value-row h3 {
      margin: 0;
    }

    .value-row p {
      margin: 0;

      font-size: 1rem;
      line-height: 1.5;
    }
  }
</style>

<script>
  const burger = document.querySelector('.burger');
  const navbar = document.querySelector('.navbar');

  if (burger && navbar) {
    burger.addEventListener('click', () => {
      navbar.classList.toggle('open');
    });
  }

  const dropdownToggle = document.querySelector('.dropdown-toggle');
  const dropdownMenu = document.querySelector('.dropdown-menu');

  if (dropdownToggle && dropdownMenu) {
    dropdownToggle.addEventListener('click', () => {
      dropdownMenu.classList.toggle('open');
    });
  }

  const slideElements = document.querySelectorAll('.slide-in');

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, {
    threshold: 0.2
  });

  slideElements.forEach((element) => {
    observer.observe(element);
  });

  const pageBg = document.querySelector('.page-bg') as HTMLElement;

  window.addEventListener('scroll', () => {
    if (pageBg) {
      const scrollY = window.scrollY;

      pageBg.style.transform =
        `translateY(${-scrollY * 0.15}px)`;
    }
  });
</script>