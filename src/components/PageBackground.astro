<div class="page-bg"></div>

<style>
  .page-bg {
    position: fixed;
    inset: 0;

    width: 100%;
    height: 100dvh;
    min-height: 100vh;

    background:
      linear-gradient(rgba(0,0,0,.45), rgba(0,0,0,.45)),
      url('/backgrounds/widabackground.png');

    background-size:
      cover,
      cover;

    background-position:
      center,
      center var(--bg-y, 50%);

    background-repeat:
      no-repeat,
      no-repeat;

    z-index: -1;
    pointer-events: none;
  }
</style>

<script>
  const pageBg = document.querySelector('.page-bg') as HTMLElement | null;

  let ticking = false;

  const updateBackground = () => {
    if (!pageBg) return;

    const documentHeight = document.documentElement.scrollHeight;
    const viewportHeight = window.innerHeight;
    const scrollableHeight = Math.max(documentHeight - viewportHeight, 1);

    const scrollProgress = window.scrollY / scrollableHeight;

    const isMobile = window.matchMedia('(max-width: 800px)').matches;

    const startPosition = 45;
    const movement = isMobile ? 18 : 30;

    const backgroundY = startPosition + scrollProgress * movement;

    pageBg.style.setProperty('--bg-y', `${backgroundY}%`);

    ticking = false;
  };

  const requestUpdate = () => {
    if (ticking) return;

    ticking = true;
    window.requestAnimationFrame(updateBackground);
  };

  window.addEventListener('scroll', requestUpdate);
  window.addEventListener('resize', requestUpdate);

  updateBackground();
</script>