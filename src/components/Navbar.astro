<button class="burger">&#9776;</button>

<nav class="navbar">
  <a href="/">Home</a>

  <button class="dropdown-toggle">
    Teams <span class="dropdown-icon">+</span>
  </button>

  <div class="dropdown-menu">
    <a href="/teams/pro">ECL Pro Team</a>
    <a href="/teams/lite">ECL Lite Team</a>
    <a href="/teams/core">ECL Core Team</a>
  </div>

  <a href="/stats">Stats</a>
  <a href="/news">News</a>
  <a href="/contact">Contact</a>
  <a href="/about">About us</a>
</nav>

<style>
.burger {
  position: fixed;
  top: 2rem;
  left: 2rem;

  width: 54px;
  height: 54px;

  display: flex;
  align-items: center;
  justify-content: center;

  background: rgba(0,0,0,.55);
  backdrop-filter: blur(10px);

  border: 0px ;
  border-radius: 14px;

  color: white;
  font-size: 2rem;
  line-height: 1;

  cursor: pointer;
  z-index: 1000;

  transition:
    background 0.2s ease,
    border-color 0.2s ease,
    transform 0.2s ease;
}

.burger:hover {
  background: rgba(0,0,0,.75);
  border-color: rgba(103,149,64,.7);
  transform: translateY(-2px);
}

  .navbar {
    position: fixed;
    z-index: 999;

    top: 0;
    left: 0;
    bottom: 0;

    height: 100vh;
    width: 250px;

    background: rgba(0,0,0,.9);
    backdrop-filter: blur(10px);

    display: flex;
    flex-direction: column;
    align-items: flex-start;

    padding-top: 6rem;

    transform: translateX(-100%);
    transition: transform .3s ease;
  }

  .navbar.open {
    transform: translateX(0);
  }

  .navbar a,
  .dropdown-toggle {
    width: 100%;

    color: white;
    text-decoration: none;

    padding: 1rem 2rem;

    font-family: 'Michroma', sans-serif;
    font-size: 1.1rem;

    text-align: left;
  }

  .dropdown-toggle {
    background: transparent;
    border: none;

    cursor: pointer;

    display: flex;
    align-items: center;
    justify-content: flex-start;

    gap: 0.5rem;
  }

  .dropdown-menu {
    display: flex;
    flex-direction: column;

    width: 100%;

    background: transparent;
    max-height: 0;

    opacity: 0;

    overflow: hidden;

    transform: translateY(-10px);

    transition:
      max-height 0.35s ease,
      opacity 0.25s ease,
      transform 0.35s ease;
  }

  .dropdown-menu a {
    padding-left: 3rem;
    font-size: 0.95rem;
    opacity: 0.85;
  }

  .dropdown-menu.open {
    max-height: 300px;
    opacity: 1;
    transform: translateY(0);
  }

  .dropdown-icon {
    font-size: 0.9rem;
    font-weight: 400;
    opacity: 0.8;
    transition: transform 0.2s ease;
  }

  @media (max-width: 800px) {
    .burger {
        top: 1.2rem;
        left: 1.2rem;

        width: 48px;
        height: 48px;

        font-size: 1.7rem;
        border-radius: 12px;
  }

    .navbar {
      width: 230px;
    }

    .navbar a,
    .dropdown-toggle {
      font-size: 1rem;
    }
  }
</style>

<script>
  const burger = document.querySelector('.burger');
  const navbar = document.querySelector('.navbar');

  if (burger && navbar) {
    burger.addEventListener('click', () => {
      navbar.classList.toggle('open');
    });
  }

  const dropdownToggle = document.querySelector('.dropdown-toggle');
  const dropdownMenu = document.querySelector('.dropdown-menu');

  if (dropdownToggle && dropdownMenu) {
    dropdownToggle.addEventListener('click', () => {
      dropdownMenu.classList.toggle('open');

      const icon = dropdownToggle.querySelector('.dropdown-icon');

      if (icon) {
        if (dropdownMenu.classList.contains('open')) {
          icon.textContent = '-';
        } else {
          icon.textContent = '+';
        }
      }
    });
  }
</script>